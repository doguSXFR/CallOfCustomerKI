# Twilio
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+43xxxxx

# Deepgram (STT - Speech-to-Text, real-time streaming)
DEEPGRAM_API_KEY=xxxxx

# ElevenLabs (TTS - Text-to-Speech, streaming)
ELEVENLABS_API_KEY=xxxxx
ELEVENLABS_VOICE_ID=xxxxx

# MiniMax (TTS - Text-to-Speech)
MINIMAX_API_KEY=xxxxx
MINIMAX_GROUP_ID=xxxxx
MINIMAX_VOICE_ID=German_SweetLady
TTS_PROVIDER=elevenlabs

# OpenAI (LLM inference — works with any OpenAI-compatible API)
OPENAI_API_KEY=sk-xxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# Examples for other providers:
# OPENAI_BASE_URL=https://api.minimax.chat/v1
# OPENAI_BASE_URL=http://localhost:11434/v1  (Ollama)

# Server
PORT=3000
HOST=0.0.0.0
